# ── LEXIDY SALES HUB BACKEND ──────────────────────────────────
# Copy to .env and fill in. Never commit .env.

# Server
PORT=3001

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://sales-hub.lexidy.com

# Postgres connection
DATABASE_URL=postgres://user:password@localhost:5432/lexidy_sales_hub
DB_SSL=false

# Auth — generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=
ADVISOR_PASSWORD=

# HubSpot private app token (Settings → Integrations → Private Apps)
# Scopes needed: crm.objects.contacts.read, crm.objects.notes.write
HUBSPOT_API_KEY=
